<% content_for :content do %>
  <header class="app_header">
    <nav class="app_header_button_container">
      <%= link_to app_dashboard_path, class: "app_header_button#{' app_header_button_current_page' if current_page?(app_dashboard_path) or current_page?(app_dashboard_edit_path)}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M120-520v-320h320v320H120Zm0 400v-320h320v320H120Zm400-400v-320h320v320H520Zm0 400v-320h320v320H520ZM200-600h160v-160H200v160Zm400 0h160v-160H600v160Zm0 400h160v-160H600v160Zm-400 0h160v-160H200v160Zm400-400Zm0 240Zm-240 0Zm0-240Z"/></svg>
        <span>Dashboard</span>
      <% end %>
      <%= link_to app_database_path, class: "app_header_button#{' app_header_button_current_page' if current_page?(controller: 'app', action: 'database')}" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M320-80q-33 0-56.5-23.5T240-160v-480q0-33 23.5-56.5T320-720h480q33 0 56.5 23.5T880-640v480q0 33-23.5 56.5T800-80H320Zm0-80h200v-120H320v120Zm280 0h200v-120H600v120ZM80-240v-560q0-33 23.5-56.5T160-880h560v80H160v560H80Zm240-120h200v-120H320v120Zm280 0h200v-120H600v120ZM320-560h480v-80H320v80Z"/></svg>
        <span>Database</span>
      <% end %>
    </nav>
    <nav class="app_header_button_container">
      <% if current_page?(app_dashboard_path) %>
        <%= link_to app_dashboard_edit_path, class: "app_header_icon_only_link" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"/></svg>
        <% end %>
      <% end %>
      <% if current_page?(app_dashboard_edit_path) %>
        <%= link_to app_dashboard_path, class: "app_header_icon_only_link" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
        <% end %>
      <% end %>
      <%= button_to "Logout", session_path, method: :delete, class: "app_header_link" %>
    </nav>
  </header>
  <main class="app_main">
    <%= yield %>
  </main>
<% end %>
<%= render template: 'layouts/application' %>
