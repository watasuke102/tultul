<h1>パスワードをリセットする</h1>

<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>

<p>パスワードをリセットするには、登録済みのメールアドレスを入力してください。パスワードをリセットする手順が記載されたメールが送信されます。</p>

<%= form_with url: passwords_path do |form| %>
  <div class="form">
    <%= form.label :email_address, "メールアドレス" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
  </div>
  <%= form.submit "メールを送信" %>
<% end %>

<%= link_to "ログインページに戻る", new_session_path %>
