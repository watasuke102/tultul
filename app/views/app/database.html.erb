<%= turbo_frame_tag "database_container" do %>
  <nav class="database_menu">
    <select onchange="Turbo.visit('<%= app_database_path %>/' + event.target.value, {action: 'advance', frame: 'database_container'})">
      <option value="">---データベースを選択---</option>
      <% @user.databases.each do |db| %>
        <option value="<%= db.id %>" <%= "selected" if db.id.to_s == params[:id] %>><%= db.title %></option>
      <% end %>
    </select>
    <%= button_to databases_path, method: :post, class: "database_add_button" do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M440-120v-320H120v-80h320v-320h80v320h320v80H520v320h-80Z"/></svg>
    <% end %>
  </nav>

  <% if params[:id] == nil %>
    <p>データベースを選択してください。</p>
  <% else %>
    <%= render @user.databases.find(params[:id]) %>
  <% end %>
<% end %>
