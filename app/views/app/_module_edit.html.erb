<% case layout.direction %>
<% when 'horizontal' %>
<div class="layout_container component_container component_container_editing" style="grid-template-columns: repeat(<%= layout.contents.length %>, 1fr);">
<% when 'vertical' %>
<div class="layout_container component_container component_container_editing" style="grid-template-rows: repeat(<%= layout.contents.length %>, 1fr);">
<% end %>

<div class="layout_editing_tag layout_editing_tag_for_component">
  <%= button_to switch_direction_layout_path(layout), method: :post, class: "layout_editing_tag_button" do %>
    <% case layout.direction %>
    <% when 'horizontal' %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="m700-300-57-56 84-84H120v-80h607l-83-84 57-56 179 180-180 180Z"/></svg>
    <% when 'vertical' %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M480-240 240-480l56-56 144 144v-368h80v368l144-144 56 56-240 240Z"/></svg>
    <% end %>
  <% end %>
  <span>Modules</span>
  <%= button_to create_child_layout_path(layout), method: :post, class: "layout_editing_tag_button" do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M440-120v-320H120v-80h320v-320h80v320h320v80H520v320h-80Z"/></svg>
  <% end %>
  <%= button_to delete_layout_path(layout), method: :delete, class: "layout_editing_tag_button",
    data: { turbo_confirm: "削除したレイアウトは復元できません。\nこのレイアウトを削除してもよろしいですか？" } do
  %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"/></svg>
  <% end %>
</div>

<% layout.contents.each_with_index do |child_module, i| %>
  <%= form_with url: update_layout_path(layout, i), method: :patch, class: "module_edit_container", data: {
      controller: "dashboardEditForm",
      layout_id: layout.id.to_s,
      contents_index: i,
      authenticity_token: form_authenticity_token
    } do |f|
  %>
    <select name="module[type]" data-action="dashboardEditForm#onTypeUpdated">
      <%= options_for_select(available_module_types, child_module['type']) %>
    </select>
    <button type="submit" class="module_edit_save_button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
    </button>
      <% case child_module['type'] %>
      <% when 'text' %>
      <div class="module_edit_area module_edit_area_text">
        <%= f.label "#{layout.id}_#{i}_font_size",  "文字サイズ" %>
        <%= f.number_field "module[font_size]", id: "#{layout.id}_#{i}_font_size", value: child_module['font_size'] %>
        <%= f.label "#{layout.id}_#{i}_text_align", "文字の揃え位置" %>
        <%= f.select "module[text_align]", ['left', 'center', 'right'], selected: child_module['text_align'], id: "#{layout.id}_#{i}_text_align" %>
        <%= f.textarea "module[text]", id: "#{layout.id}_#{i}_text", value: child_module['text'] %>

      <% else %>
      <div>
      <% end %>
    </div>
  <% end %>
<% end %>

</div>
